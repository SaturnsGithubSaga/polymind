# PolyMind — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# OpenRouter API key — required for all OpenRouter-routed models (free + paid)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini API key — required only for Gemini Flash Pro (direct Google billing)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# LiteLLM master key — any random string you choose (internal auth between app and LiteLLM)
# Example: openssl rand -hex 32
LITELLM_MASTER_KEY=change_me_to_a_random_secret_string

# Port PolyMind is exposed on (default 7860)
APP_PORT=7860
